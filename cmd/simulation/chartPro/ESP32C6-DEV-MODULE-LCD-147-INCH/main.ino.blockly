<!-- blockly-format-v5 -->
<xml xmlns="https://developers.google.com/blockly/xml"><block type="arduino_setup" id="+3KS.,QJWg/Zes~4u#@q" x="20" y="20"><statement name="SETUP"><block type="serial_begin" id="+br^6eG)x5zMkJ|X$`:t"><field name="BAUD">115200</field><next><block type="delay_ms" id="b3Pta0:Sd=ONAR+7H[Iq"><value name="MS"><block type="math_number" id="]!i)S0@u)Tw/o{{IV:Yz"><field name="NUM">500</field></block></value><next><block type="raw_code" id="F0Fn_Mi:;qY(|RjL{,a`"><value name="CODE"><block type="text" id="x+4Nc+q3Nq3Z/HOXVD96"><field name="TEXT">SPI.begin(TFT_SCLK, -1, TFT_MOSI, -1)</field></block></value><next><block type="raw_code" id=";M2c,7YIanhqL}E=?[W)"><value name="CODE"><block type="text" id="0fB@Cf`j9LBt-AP/SR[x"><field name="TEXT">pinMode(TFT_BL, OUTPUT)</field></block></value><next><block type="raw_code" id="hEMcO]JiT::tGEsdJpac"><value name="CODE"><block type="text" id=":!aXE:EM@,`$,vKL7J7L"><field name="TEXT">digitalWrite(TFT_BL, HIGH)</field></block></value><next><block type="raw_code" id="3sD/1!dOV(-F#wYEG|,`"><value name="CODE"><block type="text" id="4xaw}fCqf=:J#p=[G6tZ"><field name="TEXT">tft.init(TFT_W, TFT_H)</field></block></value><next><block type="raw_code" id="JM[Floqbqr#|Fu-DoxE*"><value name="CODE"><block type="text" id=")+5O]V!m)5V}S2d+fLgu"><field name="TEXT">tft.setSPISpeed(40000000)</field></block></value><next><block type="raw_code" id="R_p:K6{57ys1yi(m}U6L"><value name="CODE"><block type="text" id="7JyO-l@rZNi%bp~PL*sQ"><field name="TEXT">tft.setRotation(0)</field></block></value><next><block type="raw_code" id="qZX!iT#?Q9.RO34(Y0*e"><value name="CODE"><block type="text" id="E`ZgtR)USRn=6`xBD:?P"><field name="TEXT">conectaWiFi()</field></block></value><next><block type="raw_code" id="d0VEB/{@bi~d(N8oUUgn"><value name="CODE"><block type="text" id="sP|H4HEXB(,hl.ZwhPQg"><field name="TEXT">webhookURL = String("http:</field></block></value><next><block type="raw_code" id="Xg6JcxO(Vf^G}TSq4bjy"><value name="CODE"><block type="text" id="1vFg+`VxPUc%_q24Igw)"><field name="TEXT">+ "/api/v1/webhook/" + PROJECT_ID</field></block></value><next><block type="serial_print" id="8srObpB.O]Ac}MT3N?JX"><value name="TEXT"><block type="text" id="-H96b#3P:*M4k8^|Fi9*"><field name="TEXT">URL: </field></block></value><next><block type="raw_code" id="=`3Py{(i(A4$Oiok/Zu]"><value name="CODE"><block type="text" id="vmW#}@Ie*:~zFH0N/Xi2"><field name="TEXT">desenhaUI()</field></block></value><next><block type="raw_code" id="XfL~M_XPnY2!B+-}e5e)"><value name="CODE"><block type="text" id="={gUz$ps.XuNm?LgMYX,"><field name="TEXT">atualizaIP()</field></block></value><next><block type="raw_code" id="3N2l4U4|O3{!Sin`56y8"><value name="CODE"><block type="text" id="JnmKI}c[(5f#/~8px:E5"><field name="TEXT">startMillis = millis()</field></block></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="arduino_loop" id="nA;0N5oX8ewQ}VqKrgw{" x="20" y="220"><statement name="LOOP"><block type="raw_code" id=".H1uJ%kv-?V,Ha.Ap(3w"><value name="CODE"><block type="text" id="mi9P5:u,8~@MQ-ik[6]y"><field name="TEXT">unsigned long now = millis()</field></block></value><next><block type="raw_code" id=":!OO@QdGkibmH|Wz[j/?"><value name="CODE"><block type="text" id="%d8uDl@2@Tg%WrzzDD.G"><field name="TEXT">if (now - lastSend &lt; INTERVAL_MS) return</field></block></value><next><block type="raw_code" id="o%+6?Iswhf57~kPW;Gbq"><value name="CODE"><block type="text" id="~Ibqnrl4Z7oDB#[YLCc3"><field name="TEXT">lastSend = now</field></block></value><next><block type="raw_code" id="J`9vPdR,N{Ioyc``K_}%"><value name="CODE"><block type="text" id="bi5#bb9GHL$[C)V6rpV8"><field name="TEXT">tick++</field></block></value><next><block type="raw_code" id="_%U3x(^6td%p*v$$9`]*"><value name="CODE"><block type="text" id="XXiXL9V?O`bI?0WZ2UnO"><field name="TEXT">float elapsed = (now - startMillis) / 1000.0f</field></block></value><next><block type="raw_code" id=";q:_+K0{f-^5l=%jb;pI"><value name="CODE"><block type="text" id="guo:H#+=fMg1WP$MSZrL"><field name="TEXT">float phase   = (elapsed / SINE_PERIOD_S) * 2.0f * (float)M_PI</field></block></value><next><block type="raw_code" id="Ryt8)$L#!ue0yog2*=4K"><value name="CODE"><block type="text" id="G|M%wpbk,_;/5q^w/+nU"><field name="TEXT">float s0 = roundf((OFFSET + AMPLITUDE * sinf(phase)) * 100.0f) / 100.0f</field></block></value><next><block type="raw_code" id="Rj3p{AVi0up8/63rvY8;"><value name="CODE"><block type="text" id="b5MTBTO.z)h`gc;kzyqy"><field name="TEXT">float s1 = roundf((OFFSET + AMPLITUDE * cosf(phase)) * 100.0f) / 100.0f</field></block></value><next><block type="raw_code" id="07v[ytyO%M+,6B.c?{QO"><value name="CODE"><block type="text" id="#7%slivEdf~.V~@c4?Tf"><field name="TEXT">if (!enviaPayload(s0, s1)) {</field></block></value><next><block type="raw_code" id="3a%P?tvei-/Z$bPAt$]J"><value name="CODE"><block type="text" id="[`]l@NkYVV%C%a3N_`dv"><field name="TEXT">erros++</field></block></value><next><block type="raw_code" id="QmlxI8/-3@_k=nOmWSXh"><value name="CODE"><block type="text" id="7SMD3`KIEJH^eP$[L,27"><field name="TEXT">if (tick % 4 == 0) {</field></block></value><next><block type="raw_code" id="A)El]ea#$+[qk|U6=yf."><value name="CODE"><block type="text" id="Q/0zN3%Do(hbY%c:#mzR"><field name="TEXT">atualizaTela(s0, s1)</field></block></value><next><block type="raw_code" id="rpe,e1oN_0:Ta*PNW+ZN"><value name="CODE"><block type="text" id="^}]H;P%WD)4u=Fx]C6]M"><field name="TEXT">if (tick % 20 == 0) {</field></block></value><next><block type="raw_code" id="rp4;%`jRH,onERcVov)E"><value name="CODE"><block type="text" id="5g-@K5uJ38$jz0:1@Oh~"><field name="TEXT">Serial.printf("tick %lu  s0=%.2f  s1=%.2f  erros=%lu\n",</field></block></value><next><block type="raw_code" id="v9EA6ws*Z]}:Ue;}3SUE"><value name="CODE"><block type="text" id="E~xzqLE/_UGIKSNDB+~w"><field name="TEXT">tick, s0, s1, erros)</field></block></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>